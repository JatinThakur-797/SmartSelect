# ==========================================
# SmartSelect Environment Variables Template
# Copy this file to '.env' and fill in your actual keys.
# ==========================================

# 🗄️ Database Configuration (PostgreSQL)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/smart_select
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# 🔑 JWT Settings (Base64 encoded string, at least 256-bits)
JWT_SECRET=bXlTdXBlclNlY3JldEtleUZvckp3dEF1dGhlbnRpY2F0aW9uU21hcnRCdXlBSQ==

# 🤖 AI Provider API Keys
# Get your key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# 📦 Product Scraper API Keys (RapidAPI)
# Get your key from: https://rapidapi.com/real-time-amazon-data-real-time-amazon-data-default/api/real-time-amazon-data
RAPIDAPI_KEY=your_rapidapi_key_here

# 🌐 CORS Allowed Origins (comma-separated list)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 🎨 Frontend Configuration (Vite)
VITE_API_URL=http://localhost:8080/api
